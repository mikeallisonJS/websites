{
  "name": "@mikeallisonjs/next-tailwind-shared-components",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/next-tailwind-shared-components/src",
  "projectType": "library",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/rollup:rollup",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/packages/next-tailwind-shared-components",
        "tsConfig": "packages/next-tailwind-shared-components/tsconfig.lib.json",
        "project": "packages/next-tailwind-shared-components/package.json",
        "entryFile": "packages/next-tailwind-shared-components/src/index.ts",
        "external": ["react", "react-dom", "react/jsx-runtime"],
        "rollupConfig": "@nx/react/plugins/bundle-rollup",
        "compiler": "swc",
        "assets": [
          {
            "glob": "packages/next-tailwind-shared-components/README.md",
            "input": ".",
            "output": "."
          },
          {
            "glob": "packages/next-tailwind-shared-components/src/utils/tailwind.config.js",
            "input": ".",
            "output": "./utils"
          }
        ]
      }
    }
  }
}
