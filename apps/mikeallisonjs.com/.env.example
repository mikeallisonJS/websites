# OpenRouter API key for the hero agent. Required.
# Create one at https://openrouter.ai/keys — free models work.
OPENROUTER_API_KEY=

# Optional. Comma-separated, ordered fallback list of OpenRouter model IDs.
# The agent sends the list with `route: "fallback"`, so OpenRouter cascades
# to the next entry if the current one is rate-limited or unavailable —
# important for free models, which saturate intermittently.
#
# Default (used when this var is unset):
#   meta-llama/llama-3.3-70b-instruct:free,
#   qwen/qwen-2.5-72b-instruct:free,
#   mistralai/mistral-small-3.2-24b-instruct:free,
#   google/gemini-2.0-flash-exp:free
#
# All entries must support tool calling. Pick from
# https://openrouter.ai/models?supported_parameters=tools&max_price=0
OPENROUTER_MODEL=
