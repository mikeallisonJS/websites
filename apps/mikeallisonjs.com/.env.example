# OpenRouter API key for the hero agent. Required.
# Create one at https://openrouter.ai/keys — free models work.
OPENROUTER_API_KEY=

# Optional. A single OpenRouter model ID to override the default.
# Defaults to `openrouter/free` (used when unset) — OpenRouter's free
# auto-router, which selects and falls back across available free models
# server-side. The model must support tool calling; pick from
# https://openrouter.ai/models?supported_parameters=tools&max_price=0
OPENROUTER_MODEL=
