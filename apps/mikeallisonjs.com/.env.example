# OpenRouter API key for the hero agent. Required.
# Create one at https://openrouter.ai/keys — free models work.
OPENROUTER_API_KEY=

# Optional. A single OpenRouter model ID to override the primary model.
# Defaults to `openai/gpt-oss-20b:free` (used when unset) — a fast, free,
# tool-calling model. `openrouter/free` (OpenRouter's free auto-router) is
# always kept as the server-side fallback. Any override must support tool
# calling; pick from
# https://openrouter.ai/models?supported_parameters=tools&max_price=0
OPENROUTER_MODEL=
